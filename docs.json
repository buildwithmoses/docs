{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "AirTrigger",
  "description": "AirTrigger lets you build and run AI agents through Claude Code — no coding required. Describe what you want in natural language, and AirTrigger handles queuing, retries, scheduling, and monitoring.",
  "colors": {
    "primary": "#D97757",
    "light": "#E0976E",
    "dark": "#D97757"
  },
  "favicon": "/images/favicon.png",
  "contextual": {
    "options": ["copy", "view", "claude"]
  },
  "navigation": {
    "dropdowns": [
      {
        "dropdown": "Documentation",
        "description": "Resources for AirTrigger",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "introduction",
              "quick-start",
              "how-it-works"
            ]
          },
          {
            "group": "Using AirTrigger with Claude Code",
            "pages": [
              "building-with-ai",
              {
                "group": "MCP Server",
                "pages": ["mcp-introduction", "mcp-tools"]
              },
              "skills",
              "mcp-agent-rules"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              {
                "group": "Agents",
                "pages": ["tasks/overview", "tasks/schemaTask", "tasks/scheduled"]
              },
              "triggering",
              "runs",
              "apikeys",
              "queue-concurrency"
            ]
          },
          {
            "group": "Dashboard",
            "pages": [
              "run-tests",
              "troubleshooting-alerts",
              "replaying",
              "bulk-actions",
              "observability/query",
              "observability/dashboards"
            ]
          },
          {
            "group": "Deployment",
            "pages": [
              "deployment/overview",
              "deploy-environment-variables",
              "github-actions"
            ]
          },
          {
            "group": "Help",
            "pages": ["community", "help-email"]
          }
        ]
      },
      {
        "dropdown": "Guides",
        "description": "Learn what you can build",
        "icon": "books",
        "groups": [
          {
            "group": "AI Agents",
            "pages": [
              "guides/ai-agents/overview",
              "guides/ai-agents/claude-code-trigger",
              "guides/ai-agents/generate-translate-copy",
              "guides/ai-agents/route-question",
              "guides/ai-agents/respond-and-check-content",
              "guides/ai-agents/translate-and-refine",
              "guides/ai-agents/verify-news-article"
            ]
          },
          {
            "group": "Use cases",
            "pages": [
              "guides/use-cases/overview",
              "guides/use-cases/data-processing-etl",
              "guides/use-cases/media-generation",
              "guides/use-cases/media-processing",
              "guides/use-cases/marketing"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png",
    "href": "https://airtrigger.io"
  },
  "api": {
    "openapi": ["openapi.yml", "v3-openapi.yaml"],
    "playground": {
      "display": "simple"
    }
  },
  "styling": {
    "codeblocks": {
      "theme": "css-variables"
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "light": "#fff",
      "dark": "#121317"
    }
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/buildwithmoses/airtrigger-platform"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/buildwithmoses/airtrigger-platform"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          {
            "label": "Dashboard",
            "href": "https://airtrigger.io"
          },
          {
            "label": "Status",
            "href": "https://status.airtrigger.io"
          }
        ]
      },
      {
        "header": "Company",
        "items": [
          {
            "label": "Blog",
            "href": "https://airtrigger.io/blog"
          },
          {
            "label": "Contact",
            "href": "https://airtrigger.io/contact"
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/v3/feature-matrix",
      "destination": "https://feedback.trigger.dev/roadmap"
    },
    {
      "source": "/v3/upgrading-from-v2",
      "destination": "/guides/use-cases/upgrading-from-v2"
    },
    {
      "source": "/v3/open-source-self-hosting",
      "destination": "/open-source-self-hosting"
    },
    {
      "source": "/v3/:slug*",
      "destination": "/:slug*"
    },
    {
      "source": "/reattempting-replaying",
      "destination": "/replaying"
    },
    {
      "source": "/tasks-overview",
      "destination": "/tasks/overview"
    },
    {
      "source": "/tasks-scheduled",
      "destination": "/tasks/scheduled"
